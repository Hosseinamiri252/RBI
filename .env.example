# Database
DB_PASSWORD=change_me_strong_password
# JWT
JWT_SECRET=change_me_minimum_64_chars_random_secret_key_here_xxxxxxxxxxxxxxxx
# MinIO
MINIO_ACCESS_KEY=iwap_minio_admin
MINIO_SECRET_KEY=change_me_minio_secret
# LDAP (set LDAP_ENABLED=true to activate)
LDAP_ENABLED=false
LDAP_URL=ldap://192.168.1.10:389
LDAP_BASE_DN=dc=company,dc=local
LDAP_USER_SEARCH_FILTER=(sAMAccountName={0})
LDAP_MANAGER_DN=CN=ldap-reader,DC=company,DC=local
LDAP_MANAGER_PASSWORD=ldap_reader_password
# OpenLDAP dev (only used with --profile dev)
LDAP_ADMIN_PASSWORD=admin_ldap_dev
